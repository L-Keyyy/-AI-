{
  "manifest_version": 3,
  "name": "Gemini Sidebar Assistant",
  "version": "1.0",
  "description": "Ask Gemini directly from a sidebar on GitHub and other sites.",
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://github.com/*",
    "*://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://github.com/*"],
      "css": ["sidebar.css"],
      "js": ["content-target.js"]
    },
    {
      "matches": ["*://gemini.google.com/*"],
      "js": ["content-gemini.js"]
    }
  ]
}
